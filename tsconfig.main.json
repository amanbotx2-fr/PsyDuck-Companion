{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,
    "noEmitOnError": true,
    "esModuleInterop": true
  },
  "include": [
    "src/ai/**/*.ts",
    "src/main/**/*.ts",
    "src/personality/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
